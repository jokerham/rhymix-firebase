rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ════════════════════════════════════════════════════════

    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function isOwner(resourceUid) {
      return isSignedIn() && uid() == resourceUid;
    }

    function getMember() {
      return get(/databases/$(database)/documents/members/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getMember().isAdmin == true;
    }

    function isBanned() {
      return isSignedIn() && getMember().status == 'banned';
    }

    function isActive() {
      return isSignedIn() && !isBanned() && getMember().status == 'active';
    }

    function inGroup(groupId) {
      return isSignedIn() && groupId in getMember().groupIds;
    }

    function getBoard(boardMid) {
      return get(/databases/$(database)/documents/boards/$(boardMid)).data;
    }

    function canReadBoard(boardMid) {
      let board = getBoard(boardMid);
      return board.readGroupId == 'guest'
             || (isSignedIn() && (board.readGroupId == 'member' || inGroup(board.readGroupId)));
    }

    function canWriteBoard(boardMid) {
      let board = getBoard(boardMid);
      return isActive() && (board.writeGroupId == 'member' || inGroup(board.writeGroupId));
    }

    function validString(field, minLen, maxLen) {
      return field is string && field.size() >= minLen && field.size() <= maxLen;
    }

    // ════════════════════════════════════════════════════════
    // MEMBERS COLLECTION
    // ════════════════════════════════════════════════════════
    match /members/{uid} {
      // Anyone signed in can read basic profile
      allow read: if isSignedIn();

      // Create own member doc on registration
      allow create: if isOwner(uid)
                    && validString(request.resource.data.nickname, 2, 20)
                    && request.resource.data.status == 'pending'
                    && request.resource.data.isAdmin == false
                    && request.resource.data.points == 0;

      // Update own profile (cannot change isAdmin, status, points)
      allow update: if (isOwner(uid)
                    && !request.resource.data.diff(resource.data).affectedKeys()
                       .hasAny(['isAdmin', 'status', 'points', 'groupIds']))
                    || isAdmin();

      // Only admin can delete members
      allow delete: if isAdmin();
    }

    // ════════════════════════════════════════════════════════
    // GROUPS COLLECTION
    // ════════════════════════════════════════════════════════
    match /groups/{groupId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ════════════════════════════════════════════════════════
    // BOARDS COLLECTION
    // ════════════════════════════════════════════════════════
    match /boards/{boardMid} {
      allow read:  if true;   // board config is public
      allow write: if isAdmin();
    }

    // ════════════════════════════════════════════════════════
    // DOCUMENTS COLLECTION
    // ════════════════════════════════════════════════════════
    match /documents/{docSrl} {
      allow read: if resource.data.status == 'public'
                  && canReadBoard(resource.data.boardMid)
                  || isOwner(resource.data.authorId)
                  || isAdmin();

      allow create: if canWriteBoard(request.resource.data.boardMid)
                    && isOwner(request.resource.data.authorId)
                    && validString(request.resource.data.title, 1, 255)
                    && request.resource.data.status in ['public', 'secret']
                    && request.resource.data.views == 0
                    && request.resource.data.votes == 0;

      allow update: if (isOwner(resource.data.authorId)
                    && !request.resource.data.diff(resource.data)
                       .affectedKeys().hasAny(['authorId', 'boardMid', 'views', 'votes']))
                    || isAdmin();

      allow delete: if isOwner(resource.data.authorId) || isAdmin();
    }

    // ════════════════════════════════════════════════════════
    // COMMENTS COLLECTION
    // ════════════════════════════════════════════════════════
    match /comments/{commentSrl} {
      allow read: if resource.data.isSecret == false
                  || isOwner(resource.data.authorId)
                  || isAdmin();

      allow create: if isActive()
                    && isOwner(request.resource.data.authorId)
                    && validString(request.resource.data.content, 1, 5000)
                    && request.resource.data.votes == 0;

      allow update: if (isOwner(resource.data.authorId)
                    && !request.resource.data.diff(resource.data)
                       .affectedKeys().hasAny(['authorId', 'docSrl', 'votes']))
                    || isAdmin();

      allow delete: if isOwner(resource.data.authorId) || isAdmin();
    }

    // ════════════════════════════════════════════════════════
    // NOTIFICATIONS COLLECTION
    // ════════════════════════════════════════════════════════
    match /notifications/{notifId} {
      allow read:   if isOwner(resource.data.uid);
      allow create: if isAdmin();   // only Cloud Functions create notifications
      allow update: if isOwner(resource.data.uid)
                    && request.resource.data.diff(resource.data)
                       .affectedKeys().hasOnly(['read']);
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }

    // ════════════════════════════════════════════════════════
    // MENUS COLLECTION
    // ════════════════════════════════════════════════════════
    match /menus/{menuId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ════════════════════════════════════════════════════════
    // SITE SETTINGS
    // ════════════════════════════════════════════════════════
    match /settings/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ════════════════════════════════════════════════════════
    // CATEGORIES (subcollection under boards)
    // ════════════════════════════════════════════════════════
    match /boards/{boardMid}/categories/{catId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ════════════════════════════════════════════════════════
    // VOTES (subcollection under documents)
    // ════════════════════════════════════════════════════════
    match /documents/{docSrl}/votes/{uid} {
      allow read:  if isSignedIn();
      allow write: if isOwner(uid) && isActive();
    }

    // ════════════════════════════════════════════════════════
    // SCRAPS (subcollection under members)
    // ════════════════════════════════════════════════════════
    match /members/{uid}/scraps/{docSrl} {
      allow read:   if isOwner(uid);
      allow write:  if isOwner(uid) && isActive();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
